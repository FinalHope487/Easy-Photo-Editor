{
  "name": "photo-editor-pro",
  "version": "1.0.0",
  "description": "A web-based photo editor packaged as a desktop application.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.photoeditor.pro",
    "productName": "Photo Editor Pro",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  },
  "author": "Your Name",
  "license": "ISC",
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  }
}
