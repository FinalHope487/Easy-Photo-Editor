{
  "name": "easy-photo-editor",
  "version": "1.0.0",
  "description": "A web-based photo editor packaged as a desktop application.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.easyphotoeditor",
    "productName": "Easy Photo Editor",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    }
  },
  "author": "Your Name",
  "license": "ISC",
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  }
}